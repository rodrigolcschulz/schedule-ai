# API / Agent integration
AI_BASE_URL=http://localhost:8001
AI_PLAN_TIMEOUT_MS=12000
AI_REFLECT_TIMEOUT_MS=12000
AI_HTTP_RETRIES=1
BUSINESS_DOMAIN=dental

# WhatsApp integration
WHATSAPP_PROVIDER=cloud
WHATSAPP_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_META_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=YOUR_META_VERIFY_TOKEN
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_NOTIFY_ON_BOOKING=true

# Persistence (API)
SCHEDULE_PERSISTENCE=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schedule_ai
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=schedule_ai
# PGUSER=postgres
# PGPASSWORD=postgres

# Python AI provider
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
MEMORY_BACKEND=memory
